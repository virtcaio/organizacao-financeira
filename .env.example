# Supabase Postgres connection string (Connection Pooling URL recommended for serverless)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true

# Direct connection URL (used by drizzle-kit for migrations only, NOT by app runtime)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Auth.js
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional, for "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase Storage (used for receipt photos)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Cron — protege o endpoint /api/cron/recurring (gerador de transações recorrentes).
# Na Vercel, defina como env var: ela envia "Authorization: Bearer <CRON_SECRET>"
# automaticamente nas execuções do cron. Gere com: openssl rand -base64 32
CRON_SECRET=replace-with-openssl-rand-base64-32

# NOTE: there is no ANTHROPIC_API_KEY here on purpose.
# The Anthropic API key is BYOK: each user pastes their own key in the app,
# stored only in localStorage on the client. Never set ANTHROPIC_API_KEY server-side.
